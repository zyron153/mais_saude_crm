# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://maissaude:maissaude@127.0.0.1:5434/maissaude_dev?sslmode=disable"

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Keycloak ───────────────────────────────────────────────────────────────
KEYCLOAK_URL="http://localhost:8080"
KEYCLOAK_REALM="maissaude"
KEYCLOAK_CLIENT_ID="api"
KEYCLOAK_CLIENT_SECRET="change-me"

# ─── Cloudflare R2 ──────────────────────────────────────────────────────────
R2_ACCOUNT_ID="your-account-id"
R2_ACCESS_KEY_ID="your-access-key"
R2_SECRET_ACCESS_KEY="your-secret-key"
R2_BUCKET_NAME="maissaude-files"
R2_PUBLIC_URL="https://files.maissaudecv.com"

# ─── App ─────────────────────────────────────────────────────────────────────
API_PORT=3001
NODE_ENV=development

# ─── Next.js ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_KEYCLOAK_URL="http://localhost:8080"
NEXT_PUBLIC_KEYCLOAK_REALM="maissaude"
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID="web"

# ─── WhatsApp (Phase 2) ───────────────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN="change-me"
WHATSAPP_PHONE_NUMBER_ID="change-me"
WHATSAPP_VERIFY_TOKEN="change-me"

# ─── Sentry ──────────────────────────────────────────────────────────────────
SENTRY_DSN=""

# ─── Encryption ──────────────────────────────────────────────────────────────
FIELD_ENCRYPTION_KEY="32-byte-hex-key-change-in-production"
